#!/usr/bin/env bash
#
# Nome: sshcopykey
# Autor: Luiz Eduardo de Oliveira Fonseca <luizeof@gmail.com>
# Organizacao: promovaweb.com <contato@promovaweb.com>
# Versao: 0.41.6
# Descricao: Copia a chave publica SSH local para um servidor remoto usando
#            autenticacao por senha. A senha pode ser informada com --pass ou
#            digitada em um prompt oculto quando --pass nao for usado.
# Uso:
#   sshcopykey --host HOST --user USUARIO [--pass SENHA] [--key ~/.ssh/id_ed25519.pub] [--port 22]
# Exemplos:
#   sshcopykey --host 192.0.2.10 --user root
#   sshcopykey --host 192.0.2.10 --user root --pass 'senha'
#   sshcopykey --host 192.0.2.10 --user deploy --key ~/.ssh/id_rsa.pub --port 2222
#
set -euo pipefail

usage() {
  echo "Uso: sshcopykey --host HOST --user USUARIO [--pass SENHA] [--key ~/.ssh/id_ed25519.pub] [--port 22]"
}

remote_host=""
remote_user=""
remote_pass=""
remote_port="22"
key_file=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --host)
      if [ "$#" -lt 2 ]; then
        echo "Erro: --host exige valor."
        exit 1
      fi
      remote_host="$2"
      shift 2
      ;;
    --host=*)
      remote_host="${1#*=}"
      shift
      ;;
    --user)
      if [ "$#" -lt 2 ]; then
        echo "Erro: --user exige valor."
        exit 1
      fi
      remote_user="$2"
      shift 2
      ;;
    --user=*)
      remote_user="${1#*=}"
      shift
      ;;
    --pass)
      if [ "$#" -lt 2 ]; then
        echo "Erro: --pass exige valor."
        exit 1
      fi
      remote_pass="$2"
      shift 2
      ;;
    --pass=*)
      remote_pass="${1#*=}"
      shift
      ;;
    --port)
      if [ "$#" -lt 2 ]; then
        echo "Erro: --port exige valor."
        exit 1
      fi
      remote_port="$2"
      shift 2
      ;;
    --port=*)
      remote_port="${1#*=}"
      shift
      ;;
    --key)
      if [ "$#" -lt 2 ]; then
        echo "Erro: --key exige valor."
        exit 1
      fi
      key_file="$2"
      shift 2
      ;;
    --key=*)
      key_file="${1#*=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Erro: opção desconhecida: $1"
      usage
      exit 1
      ;;
  esac
done

if [ -z "$remote_host" ] || [ -z "$remote_user" ]; then
  echo "Erro: informe --host e --user."
  usage
  exit 1
fi

if [ -z "$remote_pass" ]; then
  if [ -r /dev/tty ]; then
    printf "Senha SSH para %s@%s: " "$remote_user" "$remote_host" > /dev/tty
    IFS= read -r -s remote_pass < /dev/tty
    printf "\n" > /dev/tty
  else
    echo "Erro: informe --pass ou execute em um terminal interativo para digitar a senha."
    exit 1
  fi
fi

if [ -z "$remote_pass" ]; then
  echo "Erro: senha vazia."
  exit 1
fi

if ! command -v sshpass >/dev/null 2>&1; then
  echo "Erro: sshpass não encontrado. Instale o sshpass e tente novamente."
  exit 1
fi

if [ -n "$key_file" ]; then
  key_file="${key_file/#\~/$HOME}"
  if [ -f "$key_file.pub" ] && [[ "$key_file" != *.pub ]]; then
    key_file="$key_file.pub"
  fi
else
  for candidate in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub" "$HOME/.ssh/id_ecdsa.pub"; do
    if [ -f "$candidate" ]; then
      key_file="$candidate"
      break
    fi
  done
fi

if [ ! -f "$key_file" ]; then
  echo "Erro: chave pública SSH não encontrada. Gere uma com: ssh-keygen -t ed25519 -C 'email@exemplo.com'"
  exit 1
fi

public_key="$(cat "$key_file")"
if [ -z "$public_key" ]; then
  echo "Erro: chave pública vazia: $key_file"
  exit 1
fi

if printf "%s\n" "$public_key" | SSHPASS="$remote_pass" sshpass -e ssh \
  -p "$remote_port" \
  -o StrictHostKeyChecking=accept-new \
  -o PreferredAuthentications=password,keyboard-interactive \
  -o PubkeyAuthentication=no \
  -o NumberOfPasswordPrompts=1 \
  "$remote_user@$remote_host" \
  'key=$(cat) || exit 1
umask 077
mkdir -p "$HOME/.ssh" || exit 1
touch "$HOME/.ssh/authorized_keys" || exit 1
chmod 700 "$HOME/.ssh" || exit 1
chmod 600 "$HOME/.ssh/authorized_keys" || exit 1
if ! grep -qxF "$key" "$HOME/.ssh/authorized_keys"; then
  printf "%s\n" "$key" >> "$HOME/.ssh/authorized_keys"
fi'; then
  echo "Chave SSH adicionada em $remote_user@$remote_host."
else
  echo "Falha ao adicionar a chave SSH em $remote_user@$remote_host."
  exit 1
fi
